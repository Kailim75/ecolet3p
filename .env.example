# ============================================================================
# ECOLE T3P — Variables d'environnement (template)
# ============================================================================
# Copier ce fichier vers .env et remplir les valeurs.
# NE JAMAIS commit .env dans Git (voir .gitignore).
#
# Les VITE_* sont exposées au bundle côté client (public).
# Utiliser UNIQUEMENT la clé anon/publishable Supabase ici.
# La clé service_role doit rester côté Edge Functions (Deno.env).
# ============================================================================

# --- Supabase (client SPA — clés PUBLIQUES uniquement) ---
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_PROJECT_ID="<project-ref>"
VITE_SUPABASE_PUBLISHABLE_KEY="<supabase-anon-publishable-key>"

# --- Secrets côté Edge Functions (configurés via `supabase secrets set`, PAS ici) ---
# SUPABASE_SERVICE_ROLE_KEY   → serveur uniquement
# RESEND_API_KEY              → envoi emails
# ALMA_API_KEY                → paiement (sandbox ou prod)
# ALMA_ENVIRONMENT            → "sandbox" ou "production"
# TURNSTILE_SECRET_KEY        → anti-spam (à ajouter en Batch 2)
